{
    "name": "my-vendor/my-site-package",
    "type": "typo3-cms-extension",
    "description": "My Site package to follow the tutorial.",
    "homepage": "https://docs.typo3.org/permalink/t3sitepackage:start",
    "license": [
        "GPL-2.0-or-later"
    ],
    "keywords": [
        "TYPO3 CMS"
    ],
    "require": {
        "typo3/cms-core": "^14.3",
        "typo3/cms-rte-ckeditor": "^14.3",
        "typo3/cms-fluid-styled-content": "^14.3"
    },
    "suggest": {

    },
    "autoload": {
        "psr-4": {
            "MyVendor\\MySitePackage\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "my_site_package"
        }
    }
}
